# TrustVox — environment variables (Phase 8 backend, Supabase)
# Copy this file to .env.local and fill in the real values from your Supabase
# project dashboard: Project Settings → API. NEVER commit .env.local (it's git-ignored).

# --- Public (safe to expose to the browser; RLS protects the data) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only (ADMIN key — bypasses Row-Level Security). NEVER expose to the
#     browser, never prefix with NEXT_PUBLIC_. Used only by seed/trusted server code. ---
SUPABASE_SERVICE_ROLE_KEY=
